      - "{pensive}\u77A7\u77A7\u8FD9\u662F\u4EC0\u4E48\uFF01"
      Flags: 0000
      Languages_Touch: []
    - Term: moor/adventurersCrystal_start_2
      TermType: 0
      Description: 
      Languages:
      - '{pensive}You''ve got the crystal to close that cursed rift, food, and some
        upgrades for our gear.'
      - "{pensive}\u4F60\u4EEC\u62E5\u6709\u80FD\u591F\u5173\u95ED\u8BC5\u5492\u88C2\u9699\u7684\u6C34\u6676\uFF0C\u8FD8\u6709\u98DF\u7269\u548C\u5347\u7EA7\u88C5\u5907\u7684\u6750\u6599\u3002"
      Flags: 0000
      Languages_Touch: []
    - Term: moor/adventurersCrystal_start_3
      TermType: 0
      Description: 
      Languages:
      - '{taunt}Would you kindly hand all those over to us?'
      - "{taunt}\u4ECB\u610F\u628A\u8FD9\u4E9B\u4E1C\u897F\u90FD\u65E0\u507F\u8D60\u9001\u7ED9\u6211\u4EEC\u5417\uFF1F"
      Flags: 0000
      Languages_Touch: []
    - Term: moor/adventurersCrystal_start_4
