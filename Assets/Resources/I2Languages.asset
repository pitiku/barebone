      Flags: 0000
      Languages_Touch: []
    - Term: effects/status_BlightInfested
      TermType: 0
      Description: 
      Languages:
      - Explodes when dying, dealing {v1} damage and adding {v1} blight.
      - "\u6B7B\u4EA1\u65F6\u7206\u70B8\uFF0C\u9020\u6210 {v1} \u70B9\u4F24\u5BB3\u5E76\u589E\u52A0
