      Flags: 0000
      Languages_Touch: []
    - Term: mountain/unlockPriest_q2_start_14
      TermType: 0
      Description: 
      Languages:
      - "{pensive}Everything I believed in\u2014my gods, my purpose\u2014it all started
        to unravel."
      - "{pensive}\u6211\u6240\u4FE1\u4EF0\u7684\u4E00\u5207......\u4F17\u795E\u548C\u6211\u7684\u4F7F\u547D......\u5168\u90FD\u5D29\u584C\u4E86\u3002"
      Flags: 0000
      Languages_Touch: []
    - Term: mountain/unlockPriest_q2_start_15
      TermType: 0
      Description: 
      Languages:
      - '{sad}I gave my life to the divine, but when the world began to burn... they
        were silent.'
      - "{sad}\u6211\u4E3A\u795E\u660E\u732E\u51FA\u4E86\u4E00\u751F\uFF0C\u53EF\u5F53\u75DB\u82E6\u964D\u4E34\u8FD9\u4E2A\u4E16\u754C\uFF0C\u795E\u660E\u5374......\u6CA1\u6709\u56DE\u5E94\u3002"
      Flags: 0000
      Languages_Touch: []
    - Term: mountain/unlockPriest_q2_start_16
      TermType: 0
      Description: 
      Languages:
      - "{sad}And I\u2014I broke. I ran... and I just tried to forget."
      - "{sad}\u6211......\u6211\u5D29\u6E83\u4E86\uFF0C\u9003\u8DD1\u4E86......\u60F3\u8981\u5FD8\u6389\u8FD9\u4E00\u5207\u3002"
      Flags: 0000
      Languages_Touch: []
    - Term: mountain/unlockPriest_q2_start_17
      TermType: 0
      Description: 
      Languages:
      - '{positive}Well, we''re trying to stop this madness. Rift, demons, the whole
        lot.'
      - "{positive}\u6211\u4EEC\u6B63\u5728\u52AA\u529B\u963B\u6B62\u8FD9\u4E00\u5207\u2014\u2014\u88C2\u9699\u3001\u6076\u9B54\uFF0C\u6240\u6709\u7684\u707E\u96BE\u3002"
