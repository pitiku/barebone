      - '{positive}Thank this piece of Earthglass I can still remember how to smile.
        You don''t know how rare that is here!'
      - "{positive}\u591A\u4E8F\u4E86\u8FD9\u5757\u5730\u6676\u73BB\u7483\uFF0C\u6211\u8FD8\u80FD\u8BB0\u5F97\u8BE5\u600E\u4E48\u5FAE\u7B11\u3002\u4F60\u4EEC\u4E0D\u77E5\u9053\u5728\u8FD9\u91CC\u8FD9\u6709\u591A\u96BE\u5F97\uFF01"
      Flags: 0000
      Languages_Touch: []
    - Term: blighted/blightedMerchant_start_4
      TermType: 0
      Description: 
      Languages:
      - '{positive}Please, have a look at my wares. Ha! I can''t even remember when
        I last said that. Ha!'
      - "{positive}\u8BF7\u770B\u770B\u6211\u7684\u8D27\u54C1\u5427\u3002\u54C8\uFF01\u6211\u90FD\u4E0D\u8BB0\u5F97\u4E0A\u4E00\u6B21\u8BF4\u8FD9\u53E5\u8BDD\u662F\u4EC0\u4E48\u65F6\u5019\u4E86\u3002\u54C8\uFF01"
      Flags: 0000
      Languages_Touch: []
    - Term: blighted/blightedMerchant_start_5
      TermType: 0
