      - "<target>\u5728\u591C\u95F4\u6709\u6240\u597D\u8F6C\uFF0C\u4F46\u4ECD\u7136\u611F\u89C9\u4E0D\u8212\u670D\u3002"
      Flags: 0000
      Languages_Touch: []
    - Term: dark events/illnessWorsening
