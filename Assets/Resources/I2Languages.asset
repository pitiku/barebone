      - "<target>\u75C5\u5165\u818F\u8093\uFF0C\u6574\u591C\u54C0\u53F9\u3002"
      Flags: 0000
      Languages_Touch: []
    - Term: dark events/illnessSurvived
      TermType: 0
      Description: 
      Languages:
      - <target> survived this night, but doesn't look any good.
      - "<target>\u633A\u8FC7\u4E86\u4ECA\u665A\uFF0C\u4F46\u60C5\u51B5\u4E0D\u5BB9\u4E50\u89C2\u3002"
