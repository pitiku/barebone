      - "{rage}\u75F4\u5FC3\u5984\u60F3\u3002"
      Flags: 0000
      Languages_Touch: []
    - Term: moor/adventurersCrystal_start_9
      TermType: 0
      Description: 
      Languages:
      - '{sad}It''s sad that others with the same goal had to fall... But we had
