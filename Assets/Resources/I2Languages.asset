      - "{rage}\u65E9\u8BF4\u4E86\u8FD9\u7834\u5730\u65B9\u6700\u5BB9\u6613\u88AB\u4EBA\u5077\u88AD\u3002\u8D76\u7D27\u5E72\u6389\u4ED6\u4EEC\uFF01"
