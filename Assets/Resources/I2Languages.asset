      Flags: 0000
      Languages_Touch: []
    - Term: moor/cowKiller_start_option_1
      TermType: 0
      Description: 
      Languages:
      - Help and follow him to the monster's lair.
      - "\u9009\u62E9\u5E2E\u5FD9\uFF0C\u5E76\u8DDF\u4ED6\u524D\u5F80\u602A\u7269\u5DE2\u7A74\u3002"
