      - "<random_adventurer>\u9192\u4E86\u4E4B\u540E\uFF0C\u5F00\u59CB\u5403\u8D77<random_adventurer_target>\u6765\u3002\u4F46\u7A81\u7136\u95F4\uFF0C\u5176\u610F\u8BC6\u5230\u4E0D\u5BF9\u52B2\uFF0C\u5E76\u5411\u961F\u4F0D\u9053\u6B49\u3002"
